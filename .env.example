# Base de Datos (Supabase)
DATABASE_URL=             # Transaction pooler (puerto 6543)
DIRECT_URL=               # Session pooler (puerto 5432) - migraciones
SUPABASE_PASSWORD=

# App
NEXT_PUBLIC_APP_NAME=MundoBL

# Auth (NextAuth + Google OAuth)
# - En produccion: https://mundobl.com.ar
# - En dev: http://localhost:3000
# Recordá agregar AMBAS URLs (mas https://mundobl.win/api/auth/callback/google
# como backup) a "Authorized redirect URIs" del cliente OAuth en Google Cloud Console:
#   https://mundobl.com.ar/api/auth/callback/google
#   https://mundobl.win/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
NEXTAUTH_URL=
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAILS=             # CSV de emails admin

# Supabase Storage (subida de imagenes)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Integraciones externas
YOUTUBE_API_KEY=          # YouTube Data API v3
VIMEO_CLIENT_ID=
VIMEO_ACCESS_TOKEN=
GEMINI_API_KEY=           # Google Gemini (asistente IA)

# Links del proyecto (admin/info)
PROJECT_GITHUB_URL=
PROJECT_VERCEL_URL=
PROJECT_SUPABASE_URL=
